# Copy to .env and fill in. .env is git-ignored and must never be committed.

# Runtime
NODE_ENV=development
PORT=3000

# Neon Postgres connection string.
# Use the pooled (-pooler) host for app traffic; a direct host for migrations.
# Get it from the Neon console or: neonctl connection-string <branch>
#
# Use sslmode=verify-full (not require): Neon presents a valid cert, and a future
# pg/pg-connection-string major will downgrade `require` to weaker, unverified TLS.
# verify-full is the secure, future-proof value and silences the deprecation warning.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full
